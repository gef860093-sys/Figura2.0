{
  "name": "bigavatar-server",
  "version": "1.0.0",
  "description": "BigAvatar Cloud Server with stability improvements",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/dashboard.html', 'dist/dashboard.html')\"",
