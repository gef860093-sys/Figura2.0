# =============================================================================
# BigAvatar Server - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
# Variables marked [REQUIRED] must be set before the server will start.
# Variables marked [OPTIONAL] have defaults or enable optional features.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the HTTP server listens on
PORT=80

# Max old-space heap size in MB (passed to --max-old-space-size)
MAX_OLD_SPACE_MB=512

# Fraction of max heap at which memory-pressure events are emitted (0–1)
MEMORY_PRESSURE_THRESHOLD=0.85

# Request timeout in milliseconds; responds HTTP 408 if exceeded
REQUEST_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------

# [REQUIRED] API key used to authenticate outbound calls to the upstream API
API_KEY=

# Base URL of the upstream API
API_URL=https://bigavatar.dpdns.org/api.php

# Password for the /admin dashboard
DASHBOARD_PASS=admin123

# Server geographic zone (TH | SG | JP)
SERVER_ZONE=TH

# Enable IP/token whitelist enforcement (true | false)
ENABLE_WHITELIST=true

# Maximum age of an auth token in milliseconds (default: 6 hours)
TOKEN_MAX_AGE_MS=21600000

# -----------------------------------------------------------------------------
# Redis
# [OPTIONAL] When REDIS_URL is set the server uses Redis for rate limiting,
# anti-spam state, and caching. Without it, in-process fallbacks are used.
# -----------------------------------------------------------------------------

# Redis connection URL, e.g. redis://localhost:6379
REDIS_URL=

# Timeout for establishing a Redis connection (ms)
REDIS_CONNECT_TIMEOUT_MS=5000

# Timeout for individual Redis commands (ms)
REDIS_COMMAND_TIMEOUT_MS=2000

# Maximum reconnect back-off delay (ms)
REDIS_MAX_RETRY_DELAY_MS=30000

# Time Redis must be disconnected before health status becomes "degraded" (ms)
REDIS_DEGRADED_AFTER_MS=60000

# -----------------------------------------------------------------------------
# Upload Pipeline
# -----------------------------------------------------------------------------

# Maximum allowed upload file size in bytes (default: 50 MB)
UPLOAD_MAX_FILE_SIZE_BYTES=52428800

# Maximum number of avatar versions to keep per user (default: 10)
AVATAR_MAX_VERSIONS=10

# Directory where avatar version history is stored
AVATAR_VERSIONS_DIR=./avatars_versions

# -----------------------------------------------------------------------------
# Backup System
# -----------------------------------------------------------------------------

# Directory where backup archives are stored
BACKUP_DIR=./backups

# How often to auto-backup (ms, default: 1 hour)
BACKUP_INTERVAL_MS=3600000

# Maximum number of backup archives to retain
BACKUP_MAX_KEEP=24

# Comma-separated list of allowed MIME types (validated via magic bytes)
UPLOAD_ALLOWED_MIME_TYPES=application/octet-stream

# Directory for in-progress temp files
UPLOAD_TEMP_DIR=./avatars_tmp

# Directory where completed uploads are stored
UPLOAD_FINAL_DIR=./avatars

# How often the temp-file cleaner runs (ms)
UPLOAD_CLEANER_INTERVAL_MS=600000

# Maximum age of a temp file before the cleaner deletes it (ms)
UPLOAD_MAX_TEMP_AGE_MS=1800000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Upload endpoint rate-limit window (ms)
RATE_LIMIT_UPLOAD_WINDOW_MS=60000

# Maximum upload requests allowed per window per client
RATE_LIMIT_UPLOAD_MAX=20

# API endpoint rate-limit window (ms)
RATE_LIMIT_API_WINDOW_MS=60000

# Maximum API requests allowed per window per client
RATE_LIMIT_API_MAX=300

# -----------------------------------------------------------------------------
# Anti-Spam
# -----------------------------------------------------------------------------

# Number of violations within the window before a ban is issued
ANTI_SPAM_VIOLATIONS_BEFORE_BAN=5

# Sliding window for counting violations (ms)
ANTI_SPAM_VIOLATION_WINDOW_MS=600000

# Initial ban duration (ms)
ANTI_SPAM_BAN_DURATION_MS=900000

# How much each additional request during a ban extends it (ms)
ANTI_SPAM_BAN_EXTENSION_MS=900000

# Hard cap on total ban duration (ms; default: 24 hours)
ANTI_SPAM_MAX_BAN_DURATION_MS=86400000

# -----------------------------------------------------------------------------
# WebSocket
# -----------------------------------------------------------------------------

# Interval between heartbeat pings (ms)
WS_PING_INTERVAL_MS=30000

# Time to wait for a pong before terminating the connection (ms)
WS_PONG_TIMEOUT_MS=10000

# Maximum number of concurrent WebSocket connections
WS_MAX_CONNECTIONS=10000

# Maximum allowed message size in bytes (default: 1 MB)
WS_MAX_MESSAGE_BYTES=1048576

# Maximum WebSocket messages per client per minute
WS_MAX_MSG_RATE_PER_MIN=50

# -----------------------------------------------------------------------------
# Health Monitor
# -----------------------------------------------------------------------------

# How often the health snapshot is refreshed (ms)
HEALTH_REFRESH_INTERVAL_MS=15000

# Disk free-space threshold below which disk status becomes "degraded" (bytes; default: 500 MB)
HEALTH_DISK_WARN_FREE_BYTES=524288000

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------

# Maximum time to wait for in-flight requests to drain before force-exiting (ms)
SHUTDOWN_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level (error | warn | info | debug)
LOG_LEVEL=info

# Maximum size of a single log file before rotation (bytes; default: 50 MB)
LOG_MAX_FILE_SIZE_BYTES=52428800

# Number of rotated log files to retain
LOG_MAX_FILES=14

# Directory where log files are written
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# Notifications
# [OPTIONAL] Set DISCORD_WEBHOOK_URL to enable Discord alert notifications.
# -----------------------------------------------------------------------------

DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Metrics & Alerting
# [OPTIONAL] Thresholds for Discord alert notifications.
# -----------------------------------------------------------------------------

# Heap fraction (0–1) above which a RAM alert fires
ALERT_RAM_THRESHOLD=0.85

# Disk free bytes below which a disk alert fires (default: 500 MB)
ALERT_DISK_WARN_FREE_BYTES=524288000

# How long Redis must be disconnected before alerting (ms)
ALERT_REDIS_DOWN_THRESHOLD_MS=60000

# How often the alerting module polls the health monitor (ms)
ALERT_POLL_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Admin API Key Auth
# -----------------------------------------------------------------------------

# Admin API key (used for /admin/* endpoints via Authorization: Bearer <key>)
ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Webhook Events
# -----------------------------------------------------------------------------

# External webhook URL to notify on events (avatar.uploaded, user.login, etc.)
WEBHOOK_URL=

# HMAC-SHA256 secret for webhook signature (X-Webhook-Signature header)
WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Player Activity Log
# -----------------------------------------------------------------------------

# Max events to keep in memory ring buffer
ACTIVITY_LOG_MAX_EVENTS=1000
